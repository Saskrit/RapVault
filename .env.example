# Pooled connection for app runtime (Neon: host contains "-pooler")
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection for Prisma migrations (Neon: host without "-pooler")
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Random secret for JWT sessions (min 32 chars). Generate: node scripts/generate-secret.mjs
AUTH_SECRET="change-this-to-a-random-32-char-string"
